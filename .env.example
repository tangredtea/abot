# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# JWT Secret for Authentication (REQUIRED in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_PASSWORD=your-secure-abot-password
MYSQL_DSN=abot:password@tcp(localhost:3306)/abot?charset=utf8mb4&parseTime=True

# Optional: Anthropic API Key
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Azure OpenAI Configuration
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Optional: Custom API Base URLs
# OPENAI_API_BASE=https://api.openai.com/v1
# ANTHROPIC_API_BASE=https://api.anthropic.com

# Application Configuration
# APP_NAME=abot
# LOG_LEVEL=info

# Server Configuration
# SERVER_PORT=3001
# WEB_PORT=3000

# Session Storage
# SESSION_TYPE=memory  # Options: memory, jsonl, mysql
# SESSION_DIR=data/sessions

# Object Storage
# OBJECT_STORE_DIR=data/objects

# Sandbox Configuration
# SANDBOX_LEVEL=none  # Options: none, basic, strict
# SANDBOX_EXEC_MEMORY_MB=512
# SANDBOX_EXEC_CPU_SECONDS=10
# SANDBOX_RATE_LIMIT=10
# SANDBOX_RATE_BURST=20

# CORS Configuration
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Development Mode
# DEV_MODE=false
